#!/usr/bin/env bash
# screenshot — take a screenshot of a page on the running dev server
#
# Usage: devtools screenshot /login
# Output: .screenshots/login_20260224_143022.png (path echoed to stdout)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../lib/config.sh"

PAGE_PATH="${1:-/}"
BASE_URL="${TEST_BASE_URL:-http://localhost:${DEV_PORT}}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
SAFE_NAME=$(echo "$PAGE_PATH" | tr '/' '_' | sed 's/^_//')
OUT_DIR=".screenshots"
OUT_FILE="${OUT_DIR}/${SAFE_NAME}_${TIMESTAMP}.png"

mkdir -p "$OUT_DIR"

npx playwright screenshot --browser chromium "$BASE_URL$PAGE_PATH" "$OUT_FILE" 2>/dev/null

echo "$OUT_FILE"
