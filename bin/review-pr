#!/usr/bin/env bash
# review-pr — AI-powered PR review using Claude CLI (subscription auth)
#
# Usage:
#   devtools review-pr              # review all open PRs (all 4 reviewers)
#   devtools review-pr 18           # review a specific PR
#   devtools review-pr --approve 18 # review + approve if no issues
#   devtools review-pr --deep 18    # (legacy alias, now default)
#   devtools review-pr --skip-test-coverage 18  # skip test coverage reviewer
#   devtools review-pr --skip-file-org 18       # skip file organization reviewer
#   devtools review-pr --skip-security 18       # skip security reviewer
#   devtools review-pr --incremental 18         # only review new commits since last review
#
# Reviewers (all run in parallel):
#   1. Sonnet correctness — bugs, error handling, data integrity
#   2. Opus complexity — unnecessary complexity, overengineering, scope creep
#   3. Sonnet test coverage — missing tests for changed code
#   4. Sonnet file organization — structural problems, repo hygiene
#   5. Sonnet security — vulnerabilities, secrets, auth, injection
#
# Requires: claude CLI (authenticated), gh CLI (authenticated)
# Cost: $0 — uses your Claude subscription, not API tokens

set -eo pipefail

LIB_DIR="$(cd "$(dirname "$0")/../lib" && pwd)"
source "${LIB_DIR}/config.sh"
source "${LIB_DIR}/helpers.sh"
source "${LIB_DIR}/agents.sh"

cd "$REPO_ROOT"

MAX_CONTEXT_BYTES="${MAX_CONTEXT_BYTES:-600000}"  # ~150K tokens — leaves room for prompt + response in 200K window

# ── Temp file cleanup ────────────────────────────────────────────────────────

# Only set EXIT trap when run directly (not sourced)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  trap cleanup_temp EXIT
fi

# ── Default values (can be overridden by sourcing script before calling main) ─

AUTO_APPROVE="${AUTO_APPROVE:-false}"
SKIP_TEST_COVERAGE="${SKIP_TEST_COVERAGE:-false}"
SKIP_FILE_ORG="${SKIP_FILE_ORG:-false}"
SKIP_SECURITY="${SKIP_SECURITY:-false}"
PR_NUMBER="${PR_NUMBER:-}"

# ── Shared JSON output format for review prompts ────────────────────────────

OUTPUT_FORMAT='Output ONLY valid JSON (no markdown fencing, no extra text):
{
  "summary": "1-2 sentence overall assessment",
  "issues": [
    {
      "file": "src/path/to/file.ts",
      "line": 42,
      "severity": "critical|warning|info",
      "message": "What is wrong and how to fix it"
    }
  ],
  "review_effort": 3,
  "security_concerns": true,
  "verdict": "approve|request_changes|comment"
}

Fields:
- review_effort: 1-5 scale (1=trivial rename, 2=simple change, 3=moderate feature, 4=complex logic, 5=architectural change). Reflects how carefully this PR needs human review.
- security_concerns: true if ANY security-relevant code was changed (auth, crypto, user input handling, API keys, permissions). false otherwise.

If there are no issues, return {"summary": "...", "issues": [], "review_effort": N, "security_concerns": false, "verdict": "approve"}.'

# ── Get PR list ──────────────────────────────────────────────────────────────

get_prs() {
  if [[ -n "$PR_NUMBER" ]]; then
    echo "$PR_NUMBER"
  else
    gh pr list --state open --json number --jq '.[].number'
  fi
}

# ── Build review context for a single PR ─────────────────────────────────────

build_context() {
  local pr="$1"
  local context_file
  context_file=$(mktemp)
  TEMP_FILES+=("$context_file")

  # PR metadata
  local pr_json
  pr_json=$(gh pr view "$pr" --json title,body,headRefName,baseRefName,files)
  local title body head_branch
  title=$(printf '%s' "$pr_json" | jq -r '.title')
  body=$(printf '%s' "$pr_json" | jq -r '.body // "No description"')
  head_branch=$(printf '%s' "$pr_json" | jq -r '.headRefName')

  # Write header safely (no heredoc expansion of user content)
  printf '# PR #%s: %s\n\n## Description\n%s\n\n## Branch\n%s\n\n' \
    "$pr" "$title" "$body" "$head_branch" > "$context_file"

  # Append diff (incremental: only since last reviewed commit)
  printf '## Diff\n' >> "$context_file"
  if [[ -n "${INCREMENTAL_BASE:-}" ]]; then
    printf '(Incremental: showing changes since %s)\n' "${INCREMENTAL_BASE:0:7}" >> "$context_file"
    git diff "${INCREMENTAL_BASE}..${head_branch}" >> "$context_file" 2>/dev/null || \
      gh pr diff "$pr" --patch >> "$context_file" 2>/dev/null || true
  else
    gh pr diff "$pr" --patch >> "$context_file" 2>/dev/null || true
  fi
  printf '\n## Changed Files (full content at HEAD)\n' >> "$context_file"

  # Append full content of each changed file (skip deleted files)
  local files_json
  files_json=$(printf '%s' "$pr_json" | jq -c '.files[] | {path: .path, status: .status}')
  while IFS= read -r file_entry; do
    [[ -z "$file_entry" ]] && continue
    local file status
    file=$(printf '%s' "$file_entry" | jq -r '.path')
    status=$(printf '%s' "$file_entry" | jq -r '.status')

    # Skip deleted files — no content to review at HEAD
    [[ "$status" == "removed" ]] && continue

    local content
    content=$(gh api "repos/{owner}/{repo}/contents/${file}?ref=${head_branch}" \
      --jq '.content' 2>/dev/null | base64 -d 2>/dev/null || echo "[binary or too large]")

    printf '\n### %s\n```\n%s\n```\n' "$file" "$content" >> "$context_file"
  done <<< "$files_json"

  # 80/20 RAG: Find callers/importers of changed files (lightweight cross-reference)
  # Only adds files that directly import a changed file — no embeddings or vector DB needed
  if command -v rg >/dev/null 2>&1; then
    local rag_files=()
    local rag_bytes=0
    local rag_limit=$(( MAX_CONTEXT_BYTES / 4 ))  # cap RAG at 25% of context budget

    while IFS= read -r file_entry; do
      [[ -z "$file_entry" ]] && continue
      local file status
      file=$(printf '%s' "$file_entry" | jq -r '.path')
      status=$(printf '%s' "$file_entry" | jq -r '.status')
      [[ "$status" == "removed" ]] && continue

      # Extract the importable name (basename without extension)
      local basename_no_ext
      basename_no_ext=$(basename "$file" | sed 's/\.[^.]*$//')
      [[ "$basename_no_ext" == "index" ]] && basename_no_ext=$(basename "$(dirname "$file")")

      # Find files that import this changed file (skip the file itself)
      local importers
      importers=$(rg -l --type-add 'code:*.{ts,tsx,js,jsx,py,sh}' -t code \
        "(import.*['\"].*${basename_no_ext}['\"]|require.*['\"].*${basename_no_ext}['\"]|from.*['\"].*${basename_no_ext}['\"])" \
        "$REPO_ROOT" 2>/dev/null | grep -v "node_modules" | grep -v "$file" | head -5) || true

      while IFS= read -r importer; do
        [[ -z "$importer" ]] && continue
        # Deduplicate and check budget
        local rel_path="${importer#$REPO_ROOT/}"
        local already_added=false
        for existing in "${rag_files[@]:-}"; do
          [[ "$existing" == "$rel_path" ]] && { already_added=true; break; }
        done
        $already_added && continue

        local file_size
        file_size=$(wc -c < "$importer" 2>/dev/null | tr -d ' ') || continue
        if [[ $(( rag_bytes + file_size )) -gt $rag_limit ]]; then
          break 2  # over budget, stop adding
        fi

        rag_files+=("$rel_path")
        rag_bytes=$(( rag_bytes + file_size ))
      done <<< "$importers"
    done <<< "$files_json"

    if [[ ${#rag_files[@]} -gt 0 ]]; then
      printf '\n## Callers/Importers of Changed Files (context)\n' >> "$context_file"
      for rag_file in "${rag_files[@]}"; do
        local content
        content=$(cat "$REPO_ROOT/$rag_file" 2>/dev/null || echo "[could not read]")
        printf '\n### %s (caller)\n```\n%s\n```\n' "$rag_file" "$content" >> "$context_file"
      done
      log "RAG context: ${#rag_files[@]} caller files (~$(( rag_bytes / 1024 ))KB)"
    fi
  fi

  # Append project rules
  if [[ -f "$REPO_ROOT/$REVIEW_RULES_FILE" ]]; then
    printf '\n## Project Rules (%s)\n' "$REVIEW_RULES_FILE" >> "$context_file"
    head -${REVIEW_RULES_MAX_LINES} "$REPO_ROOT/$REVIEW_RULES_FILE" >> "$context_file"
  fi

  # Check context size — truncate at line boundary to avoid corrupting UTF-8
  local size
  size=$(wc -c < "$context_file" | tr -d ' ')
  if [[ "$size" -gt "$MAX_CONTEXT_BYTES" ]]; then
    log "Warning: context is $(( size / 1024 ))KB — truncating to ~$(( MAX_CONTEXT_BYTES / 1024 ))KB"
    local trimmed
    trimmed=$(mktemp)
    TEMP_FILES+=("$trimmed")
    head -c "$MAX_CONTEXT_BYTES" "$context_file" | sed '$ { /^$/! s/$// }' > "$trimmed"
    mv "$trimmed" "$context_file"
  fi

  echo "$context_file"
}

# ── Post review to GitHub ───────────────────────────────────────────────────

post_review() {
  local pr="$1"
  local review_json="$2"
  local reviewer_name="${3:-Sonnet}"

  local summary verdict issue_count
  summary=$(printf '%s' "$review_json" | jq -r '.summary')
  verdict=$(printf '%s' "$review_json" | jq -r '.verdict')
  issue_count=$(printf '%s' "$review_json" | jq '.issues | length')

  # Map verdict to GitHub review event
  local event="COMMENT"
  if [[ "$verdict" == "approve" && "$AUTO_APPROVE" == "true" ]]; then
    event="APPROVE"
  elif [[ "$verdict" == "request_changes" ]]; then
    event="REQUEST_CHANGES"
  fi

  # Build review body
  local review_body
  review_body=$(printf '## %s Review\n\n**%s**\n\n' "$reviewer_name" "$summary")
  if [[ "$issue_count" -gt 0 ]]; then
    review_body+=$(printf '### Issues Found (%s)\n\n' "$issue_count")
    local issues_md
    issues_md=$(printf '%s' "$review_json" | jq -r '.issues[] | "- **\(.severity)** `\(.file):\(.line)`: \(.message)"')
    review_body+="$issues_md"
  else
    review_body+="No issues found."
  fi

  # Post the review — fall back to COMMENT if REQUEST_CHANGES fails (e.g. self-authored PR)
  gh api "repos/{owner}/{repo}/pulls/${pr}/reviews" \
    -X POST \
    --field event="$event" \
    --field body="$review_body" \
    > /dev/null 2>&1 || {
      if [[ "$event" != "COMMENT" ]]; then
        log "(${event} rejected by GitHub — falling back to COMMENT)"
        gh api "repos/{owner}/{repo}/pulls/${pr}/reviews" \
          -X POST \
          --field event="COMMENT" \
          --field body="$review_body" \
          > /dev/null || err "Failed to post ${reviewer_name} review to GitHub (PR #${pr})"
      else
        err "Failed to post ${reviewer_name} review to GitHub (PR #${pr})"
      fi
    }

  log "Posted review: ${verdict} (${issue_count} issues)"

  # Post inline comments — attempt each, let API reject invalid lines
  if [[ "$issue_count" -gt 0 ]]; then
    local commit_sha
    commit_sha=$(gh pr view "$pr" --json headRefOid --jq '.headRefOid')

    printf '%s' "$review_json" | jq -c '.issues[]' | while IFS= read -r issue; do
      local file line message severity
      file=$(printf '%s' "$issue" | jq -r '.file')
      line=$(printf '%s' "$issue" | jq -r '.line')
      message=$(printf '%s' "$issue" | jq -r '.message')
      severity=$(printf '%s' "$issue" | jq -r '.severity')

      [[ "$line" == "null" || "$line" == "0" ]] && continue

      local icon="info"
      [[ "$severity" == "warning" ]]  && icon="warning"
      [[ "$severity" == "critical" ]] && icon="CRITICAL"

      gh api "repos/{owner}/{repo}/pulls/${pr}/comments" \
        -X POST \
        --field body="**${reviewer_name} Review** [\`${icon}\`]: ${message}" \
        --field path="$file" \
        --field line="$line" \
        --field side="RIGHT" \
        --field commit_id="$commit_sha" \
        > /dev/null 2>&1 || log "  (inline comment skipped: ${file}:${line} not in diff)"
    done
  fi
}

# ── Run a review pass ────────────────────────────────────────────────────────

run_review() {
  local pr="$1"
  local prompt="$2"
  local model="$3"
  local reviewer_name="$4"
  local context_file="$5"

  info "PR #${pr}: Running ${reviewer_name} review..."

  local review_output review_stderr
  review_stderr=$(mktemp)
  TEMP_FILES+=("$review_stderr")

  review_output=$(env -u CLAUDECODE claude -p "${prompt}

$(cat "$context_file")" \
    --model "$model" \
    --output-format text \
    --max-turns 1 \
    2>"$review_stderr") || {
      err "${reviewer_name} review failed for PR #${pr}:"
      cat "$review_stderr" >&2
      return 1
    }

  local review_json
  review_json=$(parse_review_json "$review_output")

  if [[ -z "$review_json" ]]; then
    err "Failed to parse ${reviewer_name} output for PR #${pr}"
    log "Raw output (first 500 chars): ${review_output:0:500}"
    return 1
  fi

  local verdict issue_count
  verdict=$(printf '%s' "$review_json" | jq -r '.verdict')
  issue_count=$(printf '%s' "$review_json" | jq '.issues | length')

  if [[ "$issue_count" -eq 0 ]]; then
    info "PR #${pr}: ${reviewer_name} — Clean — ${verdict}"
  else
    info "PR #${pr}: ${reviewer_name} — ${issue_count} issues — ${verdict}"
  fi

  post_review "$pr" "$review_json" "$reviewer_name"
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
  # Parse args only when run directly (not sourced)
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --approve)             AUTO_APPROVE=true;         shift ;;
      --deep)                shift ;;  # legacy alias, now default behavior
      --skip-test-coverage)  SKIP_TEST_COVERAGE=true;   shift ;;
      --skip-file-org)       SKIP_FILE_ORG=true;        shift ;;
      --skip-security)       SKIP_SECURITY=true;        shift ;;
      --incremental)         INCREMENTAL=true;          shift ;;
      *)                     PR_NUMBER="$1";            shift ;;
    esac
  done

  check_deps claude gh jq

  local prs
  prs=$(get_prs)

  if [[ -z "$prs" ]]; then
    info "No open PRs to review."
    exit 0
  fi

  # Load agent prompts and append OUTPUT_FORMAT to each
  local REVIEW_PROMPT OPUS_PROMPT TEST_COVERAGE_PROMPT FILE_ORG_PROMPT SECURITY_PROMPT
  REVIEW_PROMPT="$(load_agent "review-correctness")

${OUTPUT_FORMAT}"
  OPUS_PROMPT="$(load_agent "review-complexity")

${OUTPUT_FORMAT}"
  TEST_COVERAGE_PROMPT="$(load_agent "review-test-coverage")

${OUTPUT_FORMAT}"
  FILE_ORG_PROMPT="$(load_agent "review-file-org")

${OUTPUT_FORMAT}"
  SECURITY_PROMPT="$(load_agent "review-security")

${OUTPUT_FORMAT}"

  while IFS= read -r pr; do
    [[ -z "$pr" ]] && continue
    info "Reviewing PR #${pr}..."

    # Incremental review: check for previous review marker comment
    if [[ "${INCREMENTAL:-false}" == "true" ]]; then
      local last_reviewed_sha
      last_reviewed_sha=$(gh api "repos/{owner}/{repo}/issues/${pr}/comments" \
        --jq '[.[] | select(.body | startswith("<!-- devtools-reviewed:")) | .body | capture("<!-- devtools-reviewed:(?<sha>[a-f0-9]+) -->") | .sha] | last // empty' 2>/dev/null)
      if [[ -n "$last_reviewed_sha" ]]; then
        info "Incremental mode: reviewing only commits since ${last_reviewed_sha:0:7}"
        export INCREMENTAL_BASE="$last_reviewed_sha"
      fi
    fi

    # Build context once, reuse for all review passes
    local context_file
    context_file=$(build_context "$pr")
    local context_size
    context_size=$(wc -c < "$context_file" | tr -d ' ')
    log "Context: $(( context_size / 1024 ))KB (~$(( context_size / 4 / 1000 ))K tokens)"

    # Run all reviewers in parallel
    local pids=()

    run_review "$pr" "$REVIEW_PROMPT" "sonnet" "Sonnet" "$context_file" &
    pids+=($!)

    run_review "$pr" "$OPUS_PROMPT" "opus" "Opus Architect" "$context_file" &
    pids+=($!)

    if [[ "$SKIP_TEST_COVERAGE" != "true" ]]; then
      run_review "$pr" "$TEST_COVERAGE_PROMPT" "sonnet" "Test Coverage" "$context_file" &
      pids+=($!)
    fi

    if [[ "$SKIP_FILE_ORG" != "true" ]]; then
      run_review "$pr" "$FILE_ORG_PROMPT" "sonnet" "File Organization" "$context_file" &
      pids+=($!)
    fi

    if [[ "$SKIP_SECURITY" != "true" ]]; then
      run_review "$pr" "$SECURITY_PROMPT" "sonnet" "Security" "$context_file" &
      pids+=($!)
    fi

    # Wait for all reviewers
    for pid in "${pids[@]}"; do
      wait "$pid" 2>/dev/null || true
    done

    # Post incremental review marker (tracks which SHA was last reviewed)
    local head_sha
    head_sha=$(gh pr view "$pr" --json headRefOid --jq '.headRefOid' 2>/dev/null)
    if [[ -n "$head_sha" ]]; then
      gh api "repos/{owner}/{repo}/issues/${pr}/comments" \
        -X POST \
        --field body="<!-- devtools-reviewed:${head_sha} -->
_Review completed at commit ${head_sha:0:7}. Use \`review-pr --incremental\` to review only new commits._" \
        > /dev/null 2>&1 || true
    fi

    echo ""
  done <<< "$prs"

  info "Done."
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
