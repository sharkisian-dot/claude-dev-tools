#!/usr/bin/env bash
# describe-pr — Auto-generate PR title, summary, and labels from diff
#
# Usage:
#   devtools describe-pr              # describe the current branch's PR
#   devtools describe-pr 42           # describe PR #42
#   devtools describe-pr --update 42  # update PR #42's title and body in-place
#   devtools describe-pr --dry-run    # print without posting
#
# Requires: claude CLI (authenticated), gh CLI (authenticated)

set -eo pipefail

LIB_DIR="$(cd "$(dirname "$0")/../lib" && pwd)"
source "${LIB_DIR}/config.sh"
source "${LIB_DIR}/helpers.sh"

cd "$REPO_ROOT"

PR_NUMBER=""
UPDATE_PR=false
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --update)   UPDATE_PR=true;  shift ;;
    --dry-run)  DRY_RUN=true;    shift ;;
    *)          PR_NUMBER="$1";  shift ;;
  esac
done

check_deps claude gh jq

# Find PR number
if [[ -z "$PR_NUMBER" ]]; then
  PR_NUMBER=$(gh pr view --json number --jq '.number' 2>/dev/null) || \
    die "No PR found for current branch. Specify a PR number."
fi

# Get diff and commit history
pr_json=$(gh pr view "$PR_NUMBER" --json title,body,headRefName,baseRefName,commits,files)
head_branch=$(printf '%s' "$pr_json" | jq -r '.headRefName')
base_branch=$(printf '%s' "$pr_json" | jq -r '.baseRefName')

# Build context for Claude
context=$(mktemp)
trap "rm -f '$context'" EXIT

printf '# PR #%s\n\n## Commits\n' "$PR_NUMBER" > "$context"
gh pr view "$PR_NUMBER" --json commits --jq '.commits[] | "- \(.messageHeadline)"' >> "$context"

printf '\n## Diff\n' >> "$context"
gh pr diff "$PR_NUMBER" --patch >> "$context" 2>/dev/null || true

# Cap context size
context_size=$(wc -c < "$context" | tr -d ' ')
if [[ "$context_size" -gt 400000 ]]; then
  head -c 400000 "$context" > "${context}.tmp" && mv "${context}.tmp" "$context"
fi

DESCRIBE_PROMPT='Analyze this PR diff and generate a title and description.

Output ONLY valid JSON (no markdown fencing, no extra text):
{
  "title": "Short PR title under 70 chars (imperative mood, e.g. Add X, Fix Y, Refactor Z)",
  "summary": "1-3 bullet points summarizing what changed and why",
  "labels": ["bug|feature|refactor|docs|chore|test|ci"],
  "breaking_changes": "Description of breaking changes, or null if none"
}

Guidelines:
- Title: imperative mood, concise, under 70 chars
- Summary: focus on WHAT changed and WHY, not HOW
- Labels: pick 1-2 from [bug, feature, refactor, docs, chore, test, ci]
- Only flag breaking_changes if public APIs, schemas, or configs changed incompatibly'

result=$(env -u CLAUDECODE claude -p "${DESCRIBE_PROMPT}

$(cat "$context")" \
  --model sonnet \
  --output-format text \
  --max-turns 1 2>/dev/null) || die "Claude failed to generate description"

# Parse JSON from response
result_json=$(printf '%s' "$result" | jq '.' 2>/dev/null) || \
  result_json=$(printf '%s' "$result" | sed 's/^```json$//' | sed 's/^```$//' | jq '.' 2>/dev/null) || \
  die "Failed to parse Claude's response as JSON"

title=$(printf '%s' "$result_json" | jq -r '.title')
summary=$(printf '%s' "$result_json" | jq -r '.summary')
labels=$(printf '%s' "$result_json" | jq -r '.labels | join(", ")')
breaking=$(printf '%s' "$result_json" | jq -r '.breaking_changes // empty')

# Build PR body
pr_body="## Summary
${summary}"

if [[ -n "$breaking" ]]; then
  pr_body+="

## Breaking Changes
${breaking}"
fi

pr_body+="

---
_Generated by [devtools describe-pr](https://github.com/anthropics/claude-dev-tools)_"

if [[ "$DRY_RUN" == true ]]; then
  echo "Title: $title"
  echo "Labels: $labels"
  echo ""
  echo "$pr_body"
  exit 0
fi

if [[ "$UPDATE_PR" == true ]]; then
  gh pr edit "$PR_NUMBER" --title "$title" --body "$pr_body"
  info "Updated PR #${PR_NUMBER}: ${title}"

  # Apply labels (create if they don't exist, ignore failures)
  for label in $(printf '%s' "$result_json" | jq -r '.labels[]'); do
    gh pr edit "$PR_NUMBER" --add-label "$label" 2>/dev/null || true
  done
else
  echo "Title: $title"
  echo "Labels: $labels"
  echo ""
  echo "$pr_body"
  echo ""
  info "Use --update to apply this to PR #${PR_NUMBER}"
fi
