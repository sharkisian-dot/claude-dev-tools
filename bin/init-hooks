#!/usr/bin/env bash
# init-hooks — Generate Claude Code hooks for deterministic quality checks
#
# Usage:
#   devtools init-hooks              # generate .claude/settings.json for current project
#   devtools init-hooks --dry-run    # print generated config without writing
#
# Generates stop hooks that run after file-write tool uses only (Edit, Write).
# Configurable via .devtools.yaml static_analysis section.

set -eo pipefail

LIB_DIR="$(cd "$(dirname "$0")/../lib" && pwd)"
source "${LIB_DIR}/config.sh"
source "${LIB_DIR}/helpers.sh"

DRY_RUN=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    -h|--help)
      sed -n '2,10p' "$0" | grep '^#' | sed 's/^# \?//'
      exit 0 ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Build hooks array from configured commands
hooks=()

if [[ -n "$STATIC_ANALYSIS_TYPECHECK" ]]; then
  hooks+=("{
      \"matcher\": \"stop\",
      \"hooks\": [
        {
          \"type\": \"command\",
          \"command\": \"$STATIC_ANALYSIS_TYPECHECK\",
          \"description\": \"Type check after edits\",
          \"on_tools\": [\"Edit\", \"Write\"]
        }
      ]
    }")
fi

if [[ -n "$STATIC_ANALYSIS_LINT" ]]; then
  hooks+=("{
      \"matcher\": \"stop\",
      \"hooks\": [
        {
          \"type\": \"command\",
          \"command\": \"$STATIC_ANALYSIS_LINT\",
          \"description\": \"Lint check after edits\",
          \"on_tools\": [\"Edit\", \"Write\"]
        }
      ]
    }")
fi

if [[ -z "${hooks[*]}" ]]; then
  echo "No static analysis commands configured in .devtools.yaml."
  echo "Add typecheck_command or lint_command under static_analysis section."
  echo "See .devtools.yaml.example for options."
  exit 1
fi

# Build the full settings JSON
hooks_json=$(printf '%s,' "${hooks[@]}" | sed 's/,$//')

settings="{
  \"hooks\": [
    $hooks_json
  ]
}"

# Pretty-print with jq if available
if command -v jq >/dev/null 2>&1; then
  settings=$(printf '%s' "$settings" | jq '.')
fi

if [[ "$DRY_RUN" == true ]]; then
  echo "Would write to ${REPO_ROOT}/.claude/settings.json:"
  echo ""
  echo "$settings"
  exit 0
fi

# Write settings file
mkdir -p "${REPO_ROOT}/.claude"
target="${REPO_ROOT}/.claude/settings.json"

if [[ -f "$target" ]]; then
  echo "⚠️  ${target} already exists."
  echo "   Merge the hooks manually or delete the file and re-run."
  echo ""
  echo "Generated hooks:"
  echo "$settings"
  exit 1
fi

printf '%s\n' "$settings" > "$target"
echo "✅ Generated ${target}"
echo ""
echo "Hooks will run after Edit/Write tool uses only (not after reads)."
echo "To disable: delete ${target} or remove the hooks array."
