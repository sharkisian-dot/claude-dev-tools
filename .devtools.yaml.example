# .devtools.yaml — Project configuration for claude-dev-tools
#
# Place this file in the root of your project repo.
# All paths are relative to the repo root.

project:
  name: "My Project"
  test_command: "npm test"
  build_command: "npm run build"
  dev_command: "npm run dev"
  dev_port: 3000

# Lane container configuration
lane:
  image: "myproject-dev"
  worktrees_dir: "../myproject-lanes"
  dockerfile: "Dockerfile.dev"

# PR review configuration
review:
  rules_file: "CLAUDE.md"
  rules_max_lines: 200
  suppressions_file: ".devtools/review-suppressions.md"  # patterns reviewers should ignore

# Relay task runner configuration
relay:
  tasks_file: "TASKS.md"
  lock_dir: ".relay-locks"

# Browser-use test configuration
browser_tests:
  manifest: "browser-tests/test-manifest.json"
  dir: "browser-tests"
  # Smoke tests to run on every commit (paths relative to dir)
  smoke_tests:
    - "test_auth_login.py"
  # Setup command to run before browser tests (e.g., seed test data)
  setup_command: ""
  # Environment variables required for browser tests
  required_env:
    - BROWSER_USE_API_KEY

# Gemini integration (optional)
gemini:
  tool_path: "tools/gemini_tool.py"
  requirements: "tools/requirements.txt"

# Hygiene gate thresholds
hygiene:
  max_rules_lines: 400

# Static analysis gate (deterministic, runs before LLM gates in relay-race)
# All commands are optional — only configured commands will run.
# Commands run on changed files only (git diff --name-only).
# NOTE: Commands are split on whitespace — do not use quoted arguments
# (e.g., use a wrapper script instead of inline 'npx eslint --rule "..."').
static_analysis:
  # Type checking (fails on errors, no auto-fix)
  typecheck_command: "npx tsc --noEmit"
  # Linting (report only — used to check for unfixable issues)
  lint_command: "npx eslint --quiet"
  # Lint auto-fix (runs first, fixes what it can)
  lint_fix_command: "npx eslint --fix"
  # Formatting auto-fix
  format_command: "npx prettier --write"

# Claude Code hooks — to enforce checks during agent work, add this to
# .claude/settings.json in your project (runs only after file-write tools):
#
#   {
#     "hooks": [{
#       "matcher": "stop",
#       "hooks": [{
#         "type": "command",
#         "command": "npx tsc --noEmit",
#         "on_tools": ["Edit", "Write"]
#       }]
#     }]
#   }

# Project-specific tools registered as plugins
# plugins:
#   - path: "scripts/plugins/my-tool.sh"
#     command: "my-tool"
